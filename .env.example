# Server-only SMTP settings. Never expose these values through VITE_* variables.
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sales@atlas-stone.ru
SMTP_PASSWORD=replace-with-vk-workspace-app-password
SMTP_FROM=ATLAS STONE — сайт <sales@atlas-stone.ru>
LEAD_TO=sale@atlas-stone.ru
PORT=8787
TRUST_PROXY=false

# Public client setting. Leave empty until the customer creates a Yandex Metrica counter.
VITE_YANDEX_METRIKA_ID=
