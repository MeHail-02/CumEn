# Server-only Bitrix24 settings. Never expose these values through VITE_* variables.
BITRIX24_WEBHOOK_URL=https://b24-z5zkze.bitrix24.ru/rest/USER_ID/WEBHOOK_SECRET/
# Optional override. Leave empty to create the file field automatically.
BITRIX24_FILE_FIELD=
BITRIX24_SOURCE_ID=WEB
BITRIX24_LEAD_STATUS_ID=
PORT=8787
TRUST_PROXY=false

# Public client setting. Leave empty until the customer creates a Yandex Metrica counter.
VITE_YANDEX_METRIKA_ID=
